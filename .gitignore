# ──────────────────────────────────────────────
# Node.js
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.node_repl_history
*.tgz
package-lock.json

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.harness          # plantilla sin secretos → sí se versiona
*.key
*.pem
service-account*.json
*-key.json
credentials.json

# ──────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfstate.*.backup
terraform/tfplan.binary
terraform/*.tfvars
!terraform/terraform.tfvars.example
.terraform/
*.tfstate
*.tfstate.backup
tfplan.binary
crash.log

