{
  "name": "ingest-telemetry",
  "version": "1.0.0",
  "description": "Cloud Function 2gen - HTTP trigger para ingesta de telemetría IoT desde ESP32",
  "main": "index.js",
  "engines": { "node": "20" },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.0",
    "@google-cloud/firestore": "^7.10.0"
  },
  "devDependencies": {
    "@google-cloud/functions-framework": "^3.3.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "functions-framework --target=ingestTelemetry --port=8081",
    "test:local": "DRY_RUN_LOCAL=1 functions-framework --target=ingestTelemetry --port=8081"
  }
}
